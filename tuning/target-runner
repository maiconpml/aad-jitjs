#!/bin/bash
# Get the directory of the current script
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
EXE="$DIR/../release_build/programs/solver/solver"

# Ensure the executable exists
if [ ! -f "$EXE" ]; then
    echo "Executable $EXE not found" >&2
    exit 1
fi

# Resolve the instance path relative to the script directory
# The paths in train-instances.txt are relative to the tuning directory
INSTANCE="$DIR/$4"
SEED=$3
CONFIG_PARAMS=${@:5}

RESULT=$($EXE "$INSTANCE" --seed "$SEED" --maxMilli 60000 --autoConfig $CONFIG_PARAMS 2>/dev/null)

if [ $? -ne 0 ]; then
    echo "Solver failed" >&2
    echo "$RESULT" >&2
    exit 1
fi

# Ensure we only return a valid number to irace
# We look for lines containing only numbers (and optional decimal/minus sign)
# and take the last one found.
echo "$RESULT" | grep -E '^[0-9.-]+$' | tail -n 1
